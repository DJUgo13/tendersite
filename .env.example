## Django Core Settings (КРИТИЧНО для продакшна!)
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

## Database (MySQL)
USE_MYSQL=True
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=tendersite
MYSQL_USER=tendersite
MYSQL_PASSWORD=tendersite
MYSQL_ROOT_PASSWORD=password

## Celery / Redis
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

## Site URL (for links in emails)
SITE_URL=https://yourdomain.com/

## Email (SMTP)
EMAIL_MODE=production
EMAIL_HOST=smtp.mail.ru
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_HOST_USER=your-email@mail.ru
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=your-email@mail.ru

## Security (для продакшна с HTTPS)
SECURE_SSL_REDIRECT=True
